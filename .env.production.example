# Public domains
APP_DOMAIN=ansemland.xyz
WS_DOMAIN=ws.ansemland.xyz

# This value is baked into the Next.js browser bundle during docker build.
NEXT_PUBLIC_COLYSEUS_URL=wss://ws.ansemland.xyz

# Optional Supabase persistence. Strongly recommended for production data.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Runtime
NODE_ENV=production
