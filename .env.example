# SawahVerse environment — copy to .env and fill in what you need.
# Everything is OPTIONAL: with no env vars the game runs fully in
# local mode (file-backed API store + public Solana RPC).

# --- Solana (public, safe to expose) ---
# Custom RPC endpoint; the public mainnet endpoint rate-limits.
# Get a free one from Helius / QuickNode for production.
# NEXT_PUBLIC_RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=...

# Solana Token Gate Mint Address
NEXT_PUBLIC_TOKEN_MINT=

# --- Supabase (SERVER ONLY — never prefix these with VITE_) ---
# When both are set, the game API persists to Supabase instead of
# the local .data/sawahverse.json file. Run supabase/schema.sql first.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
